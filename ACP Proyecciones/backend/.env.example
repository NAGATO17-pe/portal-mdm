# .env.example
# =============
# Variables de entorno del backend ACP Platform.
#
# INSTRUCCIONES:
#   1. Copie este archivo como ".env" en la raíz del directorio backend/
#   2. Complete los valores reales (no commitee el .env con credenciales)
#   3. Las variables con valor por defecto son opcionales
#
# Formato: NOMBRE=valor   (sin comillas salvo que el valor tenga espacios)

# ── Entorno ────────────────────────────────────────────────────────────────────
# Perfil de ejecución: dev | test | prod
ACP_ENTORNO=dev

# ── Base de datos SQL Server ───────────────────────────────────────────────────
# Nombre o IP del servidor SQL Server
DB_SERVIDOR=LCP-PAG-PRACTIC

# Nombre de la base de datos de proyecciones
DB_NOMBRE=ACP_DataWarehose_Proyecciones

# Credenciales SQL Server (dejar vacío para usar Windows Auth / Trusted_Connection)
# DB_USUARIO=mi_usuario
# DB_CLAVE=mi_clave_secreta

# Driver ODBC instalado en el sistema (ver: Configurador de ODBC de Windows)
DB_DRIVER=ODBC Driver 17 for SQL Server

# ── Servidor HTTP ──────────────────────────────────────────────────────────────
ACP_HOST=0.0.0.0
ACP_PUERTO=8000
ACP_WORKERS=1

# Recarga automática de código (solo en dev, NUNCA en prod)
ACP_RELOAD=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos
# En dev puede incluir localhost con el puerto del portal Streamlit
ACP_CORS_ORIGENES=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8501","http://127.0.0.1:8501"]

# ── Logging ────────────────────────────────────────────────────────────────────
# Nivel: DEBUG | INFO | WARNING | ERROR | CRITICAL
ACP_LOG_NIVEL=INFO

# Formato: json (para prod/parseo) | texto (para dev/consola)
ACP_LOG_FORMATO=texto

# ── ETL ────────────────────────────────────────────────────────────────────────
# Ruta al directorio ETL (por defecto: ../ETL relativo al backend)
# ACP_ETL_DIR=D:\Proyecto2026\ACP_DWH\ACP Proyecciones\ETL

# ── API Metadata ───────────────────────────────────────────────────────────────
ACP_API_TITULO=ACP Platform API
ACP_API_VERSION=1.1.0
