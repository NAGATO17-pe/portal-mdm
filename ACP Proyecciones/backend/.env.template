# ==============================================================================
# ACP Platform - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in the required values.
# All variables prefixed with 'DB_' or 'ACP_' are handled by nucleo/settings.py.

# ── ENTORNO ───────────────────────────────────────────────────────────────────
# dev (default) | test | prod
ACP_ENTORNO=dev

# ── BASE DE DATOS (SQL Server) ────────────────────────────────────────────────
# OBLIGATORIO: Hostname o IP del servidor SQL
DB_SERVIDOR=LCP-PAG-PRACTIC
# OBLIGATORIO: Nombre del Data Warehouse
DB_NOMBRE=ACP_DataWarehose_Proyecciones
# OPCIONAL: Usuario SQL (Dejar vacío para Windows Auth / Trusted Connection)
DB_USUARIO=
# OPCIONAL: Contraseña SQL
DB_CLAVE=
# OPCIONAL: Driver instalado en el sistema
DB_DRIVER=ODBC Driver 17 for SQL Server

# ── SEGURIDAD (JWT) ───────────────────────────────────────────────────────────
# OBLIGATORIO: Clave HMAC secreta. Debe tener al menos 32 caracteres.
# Genera una pro: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACP_JWT_SECRETO=CAMBIAME_POR_UNA_CLAVE_SUPER_SECRETA_DE_32_CHARS

# ── CONFIGURACIÓN DE RED ──────────────────────────────────────────────────────
ACP_HOST=0.0.0.0
ACP_PUERTO=8000
ACP_RELOAD=True

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos en formato JSON.
ACP_CORS_ORIGENES=["http://localhost:3000", "http://localhost:8501"]

# ── LOGGING ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
ACP_LOG_NIVEL=INFO
# json | texto
ACP_LOG_FORMATO=texto

# ── ETL ───────────────────────────────────────────────────────────────────────
# Ruta absoluta al directorio ETL. Si está vacío, detecta automáticamente.
# ACP_ETL_DIR=D:/Proyecto2026/ACP_DWH/ACP Proyecciones/ETL
