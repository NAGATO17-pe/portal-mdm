# .env — Credenciales SQL Server
# Este archivo NO va a Git — está en .gitignore

# Nombre del servidor (ej: localhost, CERROPRIETO\SQLSERVER)
DB_SERVIDOR=localhost

# Nombre de la base de datos
DB_NOMBRE=ACP_Geographic_Phenology

# Driver ODBC instalado en Windows
DB_DRIVER=ODBC Driver 17 for SQL Server

# Autenticación Windows → dejar DB_USUARIO y DB_CLAVE vacíos
# Autenticación SQL Server → completar ambos
DB_USUARIO=
DB_CLAVE=
